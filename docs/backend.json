{
  "entities": {
    "Dato": {
      "title": "Dato",
      "type": "object",
      "description": "Represents a department and district pair for data import.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the dato."
        },
        "departamento": {
          "type": "string",
          "description": "The name of the department."
        },
        "departamento_codigo": {
          "type": "string",
          "description": "The code for the department."
        },
        "distrito": {
          "type": "string",
          "description": "The name of the district."
        },
        "distrito_codigo": {
          "type": "string",
          "description": "The code for the district."
        }
      },
      "required": [
        "departamento",
        "distrito"
      ]
    },
    "Departamento": {
      "title": "Departamento",
      "type": "object",
      "description": "Represents a department in Paraguay.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the department."
        }
      },
      "required": [
        "name"
      ]
    },
    "Distrito": {
      "title": "Distrito",
      "type": "object",
      "description": "Represents a district within a department.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the district."
        },
        "departmentId": {
          "type": "string",
          "description": "The ID of the department this district belongs to."
        }
      },
      "required": [
        "name",
        "departmentId"
      ]
    },
    "Imagen": {
      "title": "Imagen",
      "type": "object",
      "description": "Represents an image uploaded by a user.",
      "properties": {
        "src": {
          "type": "string",
          "description": "URL of the uploaded image (data URI)."
        },
        "alt": {
          "type": "string",
          "description": "Alt text for the image."
        },
        "tags": {
          "type": "array",
          "description": "Tags associated with the image.",
          "items": {
            "type": "string"
          }
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date associated with the image."
        },
        "category": {
          "type": "string",
          "description": "Category of the image."
        },
        "hint": {
          "type": "string",
          "description": "AI hint for the image."
        },
        "departamento": {
          "type": "string",
          "description": "The department the image belongs to."
        },
        "distrito": {
          "type": "string",
          "description": "The district the image belongs to."
        }
      },
      "required": [
        "src",
        "alt",
        "departamento",
        "distrito"
      ]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "username": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "director",
            "jefe",
            "funcionario",
            "viewer"
          ]
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "departamento": {
          "type": "string",
          "description": "The department assigned to the user."
        },
        "distrito": {
          "type": "string",
          "description": "The district assigned to the user."
        }
      },
      "required": [
        "email",
        "username",
        "role"
      ]
    },
    "Reporte": {
      "title": "Reporte",
      "type": "object",
      "description": "Represents a report with detailed information.",
      "properties": {
        "departamento": {
          "type": "string"
        },
        "distrito": {
          "type": "string"
        },
        "estado-fisico": {
          "type": "string"
        },
        "descripcion-situacion": {
          "type": "string"
        },
        "cantidad-habitaciones": {
          "type": "string"
        },
        "habitacion-segura": {
          "type": "string"
        },
        "caracteristicas-habitacion": {
          "type": "string"
        },
        "dimensiones-habitacion": {
          "type": "string"
        },
        "cantidad-maquinas": {
          "type": "string"
        },
        "lugar-resguardo": {
          "type": "string"
        }
      },
      "required": [
        "departamento",
        "distrito"
      ]
    },
    "LocalVotacion": {
      "title": "Local de Votacion",
      "type": "object",
      "description": "Represents a polling station.",
      "properties": {
        "codigo_local": {
          "type": "string",
          "description": "The code for the polling station."
        },
        "departamento": {
          "type": "string",
          "description": "The name of the department."
        },
        "distrito": {
          "type": "string",
          "description": "The name of the district."
        },
        "zona": {
          "type": "string",
          "description": "The zone of the polling station."
        },
        "local": {
          "type": "string",
          "description": "The name of the polling station."
        },
        "direccion": {
          "type": "string",
          "description": "The address of the polling station."
        },
        "gps": {
          "type": "string",
          "description": "GPS coordinates of the polling station."
        }
      },
      "required": [
        "departamento",
        "distrito",
        "local"
      ]
    },
    "SolicitudCapacitacion": {
      "title": "Solicitud de Capacitación",
      "type": "object",
      "description": "Formulario de solicitud de capacitación oficial.",
      "properties": {
        "solicitante_entidad": {
          "type": "string",
          "description": "Partido o Movimiento Político"
        },
        "tipo_solicitud": {
          "type": "string",
          "enum": [
            "divulgacion",
            "capacitacion"
          ]
        },
        "fecha": {
          "type": "string",
          "format": "date"
        },
        "hora_desde": {
          "type": "string"
        },
        "hora_hasta": {
          "type": "string"
        },
        "lugar_local": {
          "type": "string"
        },
        "direccion_calle": {
          "type": "string"
        },
        "barrio_compania": {
          "type": "string"
        },
        "departamento": {
          "type": "string"
        },
        "distrito": {
          "type": "string"
        },
        "rol_solicitante": {
          "type": "string",
          "enum": [
            "apoderado",
            "otro"
          ]
        },
        "nombre_completo": {
          "type": "string"
        },
        "cedula": {
          "type": "string"
        },
        "telefono": {
          "type": "string"
        },
        "gps": {
          "type": "string"
        },
        "foto_firma": {
          "type": "string",
          "description": "Data URI de la solicitud firmada."
        },
        "usuario_id": {
          "type": "string"
        },
        "fecha_creacion": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "solicitante_entidad",
        "tipo_solicitud",
        "fecha",
        "hora_desde",
        "hora_hasta",
        "direccion_calle",
        "nombre_completo",
        "cedula",
        "departamento",
        "distrito"
      ]
    },
    "EncuestaSatisfaccion": {
      "title": "Encuesta de Satisfacción",
      "type": "object",
      "description": "Encuesta de satisfacción del uso de la máquina de votación.",
      "properties": {
        "lugar_practica": {
          "type": "string"
        },
        "fecha": {
          "type": "string",
          "format": "date"
        },
        "hora": {
          "type": "string"
        },
        "edad": {
          "type": "string"
        },
        "genero": {
          "type": "string",
          "enum": [
            "hombre",
            "mujer",
            "pueblo_originario"
          ]
        },
        "utilidad_maquina": {
          "type": "string",
          "enum": [
            "muy_util",
            "util",
            "poco_util",
            "nada_util"
          ]
        },
        "facilidad_maquina": {
          "type": "string",
          "enum": [
            "muy_facil",
            "facil",
            "poco_facil",
            "nada_facil"
          ]
        },
        "seguridad_maquina": {
          "type": "string",
          "enum": [
            "muy_seguro",
            "seguro",
            "poco_seguro",
            "nada_seguro"
          ]
        },
        "departamento": {
          "type": "string"
        },
        "distrito": {
          "type": "string"
        },
        "usuario_id": {
          "type": "string"
        },
        "fecha_creacion": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "lugar_practica",
        "fecha",
        "hora",
        "edad",
        "genero",
        "utilidad_maquina",
        "facilidad_maquina",
        "seguridad_maquina",
        "departamento",
        "distrito"
      ]
    },
    "InformeDivulgador": {
      "title": "Informe del Divulgador (Anexo III)",
      "type": "object",
      "description": "Control individual del divulgador con marcaciones.",
      "properties": {
        "lugar_divulgacion": { "type": "string" },
        "fecha": { "type": "string", "format": "date" },
        "hora_desde": { "type": "string" },
        "hora_hasta": { "type": "string" },
        "nombre_divulgador": { "type": "string" },
        "cedula_divulgador": { "type": "string" },
        "vinculo": { "type": "string" },
        "oficina": { "type": "string" },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" },
        "total_personas": { "type": "number" },
        "marcaciones": {
          "type": "array",
          "items": { "type": "number" }
        },
        "usuario_id": { "type": "string" },
        "fecha_creacion": { "type": "string", "format": "date-time" }
      },
      "required": [
        "lugar_divulgacion",
        "fecha",
        "nombre_divulgador",
        "cedula_divulgador",
        "departamento",
        "distrito"
      ]
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/datos/{datoId}": {
      "schema": {
        "$ref": "#/entities/Dato"
      },
      "description": "Stores imported department and district data."
    },
    "/departamentos/{departamentoId}": {
      "schema": {
        "$ref": "#/entities/Departamento"
      },
      "description": "Stores department information."
    },
    "/departamentos/{departamentoId}/distritos/{distritoId}": {
      "schema": {
        "$ref": "#/entities/Distrito"
      },
      "description": "Stores district information for a specific department."
    },
    "/imagenes/{imagenId}": {
      "schema": {
        "$ref": "#/entities/Imagen"
      },
      "description": "Stores image information, linked by department and district name."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/reports/{reportId}": {
      "schema": {
        "$ref": "#/entities/Reporte"
      },
      "description": "Stores detailed report information."
    },
    "/locales-votacion/{localId}": {
      "schema": {
        "$ref": "#/entities/LocalVotacion"
      },
      "description": "Stores polling station information."
    },
    "/solicitudes-capacitacion/{solicitudId}": {
      "schema": {
        "$ref": "#/entities/SolicitudCapacitacion"
      },
      "description": "Stores training requests."
    },
    "/encuestas-satisfaccion/{encuestaId}": {
      "schema": {
        "$ref": "#/entities/EncuestaSatisfaccion"
      },
      "description": "Stores satisfaction surveys."
    },
    "/informes-divulgador/{informeId}": {
      "schema": {
        "$ref": "#/entities/InformeDivulgador"
      },
      "description": "Stores individual divulgador reports (Anexo III)."
    }
  }
}
