
{
  "entities": {
    "Dato": {
      "title": "Dato",
      "type": "object",
      "description": "Represents a department and district pair for data import.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the dato."
        },
        "departamento": {
          "type": "string",
          "description": "The name of the department."
        },
        "departamento_codigo": {
          "type": "string",
          "description": "The code for the department."
        },
        "distrito": {
          "type": "string",
          "description": "The name of the district."
        },
        "distrito_codigo": {
          "type": "string",
          "description": "The code for the district."
        }
      },
      "required": [
        "departamento",
        "distrito"
      ]
    },
    "Divulgador": {
      "title": "Divulgador",
      "type": "object",
      "description": "Personal operativo que realiza las capacitaciones, no tiene acceso al sistema.",
      "properties": {
        "nombre": { "type": "string" },
        "cedula": { "type": "string" },
        "vinculo": { "type": "string", "enum": ["PERMANENTE", "CONTRATADO", "COMISIONADO"] },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" },
        "fecha_registro": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "cedula", "departamento", "distrito"]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "username": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "director",
            "jefe",
            "funcionario",
            "viewer"
          ]
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "departamento": {
          "type": "string"
        },
        "distrito": {
          "type": "string"
        }
      },
      "required": [
        "email",
        "username",
        "role"
      ]
    },
    "SolicitudCapacitacion": {
      "title": "Solicitud de Capacitación",
      "type": "object",
      "properties": {
        "solicitante_entidad": { "type": "string" },
        "tipo_solicitud": { "type": "string" },
        "fecha": { "type": "string" },
        "hora_desde": { "type": "string" },
        "hora_hasta": { "type": "string" },
        "lugar_local": { "type": "string" },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" },
        "nombre_completo": { "type": "string" },
        "cedula": { "type": "string" },
        "divulgador_id": { "type": "string" },
        "divulgador_nombre": { "type": "string" },
        "divulgador_cedula": { "type": "string" },
        "divulgador_vinculo": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/divulgadores/{divulgadorId}": {
      "schema": { "$ref": "#/entities/Divulgador" },
      "description": "Directorio de personal operativo para capacitaciones."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/solicitudes-capacitacion/{solicitudId}": {
      "schema": {
        "$ref": "#/entities/SolicitudCapacitacion"
      },
      "description": "Stores training requests."
    }
  }
}
