{
  "entities": {
    "Dato": {
      "title": "Dato",
      "type": "object",
      "description": "Represents a department and district pair for data import.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the dato."
        },
        "departamento": {
          "type": "string",
          "description": "The name of the department."
        },
        "departamento_codigo": {
          "type": "string",
          "description": "The code for the department."
        },
        "distrito": {
          "type": "string",
          "description": "The name of the district."
        },
        "distrito_codigo": {
          "type": "string",
          "description": "The code for the district."
        }
      },
      "required": [
        "departamento",
        "distrito"
      ]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "username": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "director",
            "coordinador",
            "jefe",
            "funcionario",
            "viewer"
          ]
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "departamento": {
          "type": "string"
        },
        "distrito": {
          "type": "string"
        }
      },
      "required": [
        "email",
        "username",
        "role"
      ]
    },
    "Divulgador": {
      "title": "Divulgador",
      "type": "object",
      "description": "Personal operativo para capacitaciones.",
      "properties": {
        "nombre": { "type": "string" },
        "cedula": { "type": "string" },
        "vinculo": { "type": "string", "enum": ["PERMANENTE", "CONTRATADO", "COMISIONADO"] },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" }
      }
    },
    "PartidoPolitico": {
      "title": "Partido Político",
      "type": "object",
      "description": "Entidad política para solicitudes de capacitación.",
      "properties": {
        "nombre": { "type": "string" },
        "siglas": { "type": "string" },
        "movimiento": { "type": "string", "description": "Movimiento interno del partido." }
      }
    },
    "SolicitudCapacitacion": {
      "title": "Solicitud de Capacitación",
      "type": "object",
      "properties": {
        "solicitante_entidad": { "type": "string" },
        "tipo_solicitud": { "type": "string" },
        "fecha": { "type": "string" },
        "hora_desde": { "type": "string" },
        "hora_hasta": { "type": "string" },
        "lugar_local": { "type": "string" },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" },
        "nombre_completo": { "type": "string" },
        "cedula": { "type": "string" }
      }
    },
    "AnexoI": {
      "title": "Anexo I - Planificación Lugares Fijos",
      "type": "object",
      "properties": {
        "tipo_oficina": { "type": "string", "enum": ["REGISTRO", "CENTRO_CIVICO"] },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" },
        "fecha_creacion": { "type": "string", "format": "date-time" }
      }
    },
    "PadronItem": {
      "title": "Padrón Electoral",
      "type": "object",
      "description": "Registro oficial de ciudadanos.",
      "properties": {
        "cedula": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "departamento": { "type": "string" },
        "distrito": { "type": "string" }
      }
    },
    "InformeSemanalRegistro": {
      "title": "Informe Semanal Registro",
      "type": "object",
      "properties": {
        "departamento": { "type": "string" },
        "distrito": { "type": "string" },
        "fecha_desde": { "type": "string" },
        "fecha_hasta": { "type": "string" },
        "inscripciones_1ra_vez": { "type": "number" },
        "actualizacion_datos": { "type": "number" },
        "cambio_local": { "type": "number" },
        "cambio_distrito": { "type": "number" },
        "organizaciones_asistidas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tipo": { "type": "string" },
              "nombre": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/divulgadores/{divulgadorId}": {
      "schema": {
        "$ref": "#/entities/Divulgador"
      },
      "description": "Stores operational staff information."
    },
    "/partidos-politicos/{partidoId}": {
      "schema": {
        "$ref": "#/entities/PartidoPolitico"
      },
      "description": "Directory of political parties and movements."
    },
    "/solicitudes-capacitacion/{solicitudId}": {
      "schema": {
        "$ref": "#/entities/SolicitudCapacitacion"
      },
      "description": "Stores training requests."
    },
    "/anexo-i/{anexoId}": {
      "schema": {
        "$ref": "#/entities/AnexoI"
      },
      "description": "Stores planning for fixed disclosure places."
    },
    "/padron/{padronId}": {
      "schema": {
        "$ref": "#/entities/PadronItem"
      },
      "description": "Stores electoral register information."
    },
    "/informes-semanales-registro/{informeId}": {
      "schema": {
        "$ref": "#/entities/InformeSemanalRegistro"
      },
      "description": "Stores weekly reports from registry offices."
    }
  }
}