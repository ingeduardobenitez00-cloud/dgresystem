
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Helper Functions **/
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAssignedTo(departamento, distrito) {
      let userData = getUserData();
      return userData.departamento == departamento && userData.distrito == distrito;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /** Publicly readable data **/
    match /datos/{datoId} {
      allow read: if true;
      allow write: if isAdmin(); // Only admins can manage the base data now
    }

    match /departamentos/{departamentoId} {
      allow read: if true;
      allow write: if isAdmin();
        match /distritos/{distritoId} {
          allow read: if true;
          allow write: if isAdmin();
        }
    }

    /** Main Data Collections **/
    match /imagenes/{imagenId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        isAdmin() ||
        ( (isRole('editor') || isRole('uploader')) && isAssignedTo(request.resource.data.departamento, request.resource.data.distrito) )
      );
      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        ( (isRole('editor') || isRole('uploader')) && isAssignedTo(resource.data.departamento, resource.data.distrito) )
      );
    }

    match /reports/{reportId} {
      allow read: if true;
      // Admin or an assigned editor can create/update.
      allow create, update: if isSignedIn() && (
        isAdmin() ||
        (isRole('editor') && isAssignedTo(request.resource.data.departamento, request.resource.data.distrito))
      );
      // Only Admin or assigned editor can delete.
      allow delete: if isSignedIn() && (
        isAdmin() ||
        (isRole('editor') && isAssignedTo(resource.data.departamento, resource.data.distrito))
      );
    }

    /** User Profiles **/
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
