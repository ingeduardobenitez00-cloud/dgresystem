
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * PROTOCOLO DE ACCESO MAESTRO - V4.0
     * Bypass total para el administrador principal por token de correo.
     * Este bloque otorga permisos inmediatos sin consultas a la base de datos,
     * eliminando el error PERMISSION_DENIED en cargas masivas (Write Batches).
     */
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'edubtz11@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isActive() {
      return isSignedIn() && (getUserData() == null || getUserData().get('active', true) != false);
    }

    function isAdmin() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'admin';
    }

    function isDirector() {
      return isSignedIn() && getUserData() != null && (getUserData().role == 'admin' || getUserData().role == 'director');
    }

    function isStaff() {
      return isSignedIn() && getUserData() != null && (getUserData().role == 'admin' || getUserData().role == 'director' || getUserData().role == 'coordinador');
    }

    /** Gestión de Usuarios **/
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || isDirector();
      allow create: if isSignedIn() && request.auth.uid == userId; 
      allow update: if (request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /** Notificaciones de Sistema **/
    match /notificaciones/{notiId} {
      allow read, update: if isStaff();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    /** Regla para el Padrón Electoral **/
    match /padron/{document=**} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    /** Monitoreo de Presencia **/
    match /presencia/{userId} {
      allow read: if isAdmin() || isDirector() || (isSignedIn() && request.auth.uid == userId);
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /** CIDEE - Colecciones Transaccionales **/
    
    match /solicitudes-capacitacion/{solicitudId} {
      allow get: if true;
      allow list: if isActive();
      allow create, update: if isActive();
      allow delete: if isAdmin();
    }

    match /encuestas-satisfaccion/{encuestaId} {
      allow read: if isActive();
      allow create: if true; 
      allow update: if isActive();
      allow delete: if isAdmin();
    }

    match /anexo-i/{anexoId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /informes-divulgador/{informeId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /informes-semanales-anexo-iv/{informeId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /movimientos-maquinas/{movimientoId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    match /denuncias-lacres/{denunciaId} {
      allow read, write: if isActive();
      allow delete: if isAdmin();
    }

    /** Reglas Generales de Configuración y Geografía **/
    match /datos/{datoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partidos-politicos/{partidoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditoria/{logId} {
      allow read: if isAdmin() || isDirector();
      allow create: if isSignedIn();
    }

    match /divulgadores/{document=**} {
      allow read: if isActive();
      allow write: if isActive() || isAdmin();
    }

    match /maquinas/{maquinaId} {
      allow read: if isActive() || isAdmin();
      allow write: if isAdmin();
    }

    match /locales-votacion/{localId} {
      allow read: if isActive() || isAdmin();
      allow write: if isAdmin();
    }
    
    match /reports/{reportId} {
      allow read, write: if isActive() || isAdmin();
    }

    match /imagenes/{imagenId} {
      allow read, write: if isActive() || isAdmin();
    }

    match /informes-semanales-registro/{informeId} {
      allow read, write: if isActive() || isAdmin();
      allow delete: if isAdmin();
    }

    match /archivos-semanales-registro/{archivoId} {
      allow read: if isAdmin() || isDirector();
      allow write: if isAdmin();
    }
  }
}
