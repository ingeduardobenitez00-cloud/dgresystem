rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Helper Functions **/
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'admin';
    }
    
    function isRole(role) {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == role;
    }
    
    function isAdministrative() {
      let data = getUserData();
      if (!isSignedIn() || data == null) return false;
      let role = data.role;
      return role == 'admin' || role == 'director' || role == 'jefe';
    }
    
    function hasPermission(permission) {
      let data = getUserData();
      return isSignedIn() && data != null && 'permissions' in data && permission in data.permissions;
    }

    function isAssignedTo(departamento, distrito) {
      let data = getUserData();
      return isSignedIn() && data != null && data.departamento == departamento && data.distrito == distrito;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Publicly readable data **/
    match /datos/{datoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departamentos/{departamentoId} {
      allow read: if true;
      allow write: if isAdmin();
        match /distritos/{distritoId} {
          allow read: if true;
          allow write: if isAdmin();
        }
    }

    match /maquinas/{maquinaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /partidos-politicos/{partidoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Main Data Collections **/
    match /locales-votacion/{localId} {
      allow read: if isSignedIn();
      allow write: if isAdministrative();
    }
    
    match /imagenes/{imagenId} {
      allow read: if isAdministrative() || hasPermission('view_images');
      allow create: if isSignedIn() && (
        isAdministrative() ||
        (isRole('funcionario') && hasPermission('add') && isAssignedTo(request.resource.data.departamento, request.resource.data.distrito))
      );
      allow update, delete: if isSignedIn() && (
        isAdministrative() ||
        (isRole('funcionario') && (hasPermission('add') || hasPermission('delete')) && isAssignedTo(resource.data.departamento, resource.data.distrito))
      );
    }

    match /reports/{reportId} {
      allow read: if isAdministrative() || hasPermission('view_report');
      allow create, update: if isSignedIn() && (
        isAdministrative() ||
        (isRole('funcionario') && hasPermission('edit') && isAssignedTo(request.resource.data.departamento, request.resource.data.distrito))
      );
      allow delete: if isSignedIn() && (
        isAdministrative() ||
        (isRole('funcionario') && hasPermission('delete') && isAssignedTo(request.resource.data.departamento, request.resource.data.distrito))
      );
    }

    match /solicitudes-capacitacion/{solicitudId} {
      allow get: if isSignedIn() && (
        isAdministrative() || 
        (isRole('funcionario') && isAssignedTo(resource.data.departamento, resource.data.distrito)) ||
        (isRole('divulgador') && isAssignedTo(resource.data.departamento, resource.data.distrito))
      );
      allow list: if isSignedIn() && (isAdministrative() || isRole('funcionario') || isRole('divulgador'));
      allow create: if isSignedIn() && (
        isAdministrative() || 
        (isRole('funcionario') && isAssignedTo(request.resource.data.departamento, request.resource.data.distrito))
      );
      allow update, delete: if isAdministrative();
    }

    match /encuestas-satisfaccion/{encuestaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdministrative();
    }

    match /informes-divulgador/{informeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdministrative();
    }

    match /informes-semanales-anexo-iv/{informeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdministrative();
    }

    match /movimientos-maquinas/{movimientoId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /padron/{padronId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** User Profiles **/
    match /users/{userId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isAdmin() || (isAdministrative() && request.query.distrito == getUserData().distrito);
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
    }
  }
}