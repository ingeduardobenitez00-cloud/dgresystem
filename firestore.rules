rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // 1. REGLA MAESTRA (BYPASS ABSOLUTO POR CORREO)
    // PRIORIDAD TOTAL: Si el correo es administrador, no se evalúa nada más.
    // ======================================================

    function isMaster() {
      return request.auth != null && 
             (
               request.auth.token.email == 'edubtz11@gmail.com' || 
               request.auth.token.email == 'ing.eduardobenitez00@gmail.com' ||
               request.auth.token.email == 'eduardobritz1@gmail.com' || 
               request.auth.token.email == 'eduardobritz11@gmail.com'
             );
    }

    match /{document=**} {
      allow read, write: if isMaster();
    }

    // ======================================================
    // 2. REGLAS ESPECÍFICAS PARA OTROS USUARIOS
    // ======================================================

    match /users/{userId} {
      // Lectura: Propia o por Admin/Master
      allow read: if request.auth != null && (request.auth.uid == userId || isMaster());
      
      // Escritura: Solo Maestros (ya cubierto por el bypass global, pero se explicita)
      allow create, update: if isMaster();
      allow delete: if isMaster();
    }

    // Colecciones Operativas (Acceso general para usuarios logueados autorizados)
    match /solicitudes-capacitacion/{id} { allow read, write: if request.auth != null; }
    match /informes-divulgador/{id} { allow read, write: if request.auth != null; }
    match /informes-semanales-anexo-iv/{id} { allow read, write: if request.auth != null; }
    match /movimientos-maquinas/{id} { allow read, write: if request.auth != null; }
    match /divulgadores/{id} { allow read, write: if request.auth != null; }
    match /maquinas/{id} { allow read, write: if request.auth != null; }
    match /datos/{id} { allow read: if true; allow write: if isMaster(); }
    match /partidos-politicos/{id} { allow read: if true; allow write: if isMaster(); }
    match /encuestas-satisfaccion/{id} { allow read: if request.auth != null; allow create: if true; }
    match /notificaciones/{id} { allow read, write, create: if request.auth != null; }
    match /padron/{id} { allow read, write: if request.auth != null; }
    match /locales-votacion/{id} { allow read, write: if request.auth != null; }
    match /informes-semanales-registro/{id} { allow read, write: if request.auth != null; }
    match /anexo-i/{id} { allow read, write: if request.auth != null; }
    match /config/{id} { allow read, write: if request.auth != null; }
    match /auditoria/{id} { allow create, read: if request.auth != null; }
    match /presencia/{userId} { allow read, write: if request.auth != null && (request.auth.uid == userId || isMaster()); }
    match /archivos-semanales-registro/{id} { allow read, write: if isMaster(); }
  }
}