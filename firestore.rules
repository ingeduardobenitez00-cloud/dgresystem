
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Helper Functions **/
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'admin';
    }
    
    function isRole(role) {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == role;
    }
    
    function hasPermission(module, action) {
      let data = getUserData();
      if (!isSignedIn() || data == null) return false;
      if (data.role == 'admin') return true;
      let permString = module + ":" + action;
      return ('permissions' in data && permString in data.permissions) || (action in data.permissions);
    }

    function hasGlobalPermission(permission) {
      let data = getUserData();
      return isSignedIn() && data != null && 'permissions' in data && permission in data.permissions;
    }

    function isAssignedTo(departamento, distrito) {
      let data = getUserData();
      return isSignedIn() && data != null && data.departamento == departamento && data.distrito == distrito;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Publicly readable data **/
    match /datos/{datoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departamentos/{departamentoId} {
      allow read: if true;
      allow write: if isAdmin();
        match /distritos/{distritoId} {
          allow read: if true;
          allow write: if isAdmin();
        }
    }

    match /maquinas/{maquinaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /partidos-politicos/{partidoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Main Data Collections **/
    match /locales-votacion/{localId} {
      allow read: if isSignedIn() && hasPermission('locales-votacion', 'view');
      allow create: if hasPermission('locales-votacion', 'add');
      allow update: if hasPermission('locales-votacion', 'edit');
      allow delete: if hasPermission('locales-votacion', 'delete');
    }
    
    match /imagenes/{imagenId} {
      allow read: if hasPermission('fotos', 'view') || hasPermission('ficha', 'view');
      allow create: if isSignedIn() && (
        hasPermission('fotos', 'add') || hasPermission('ficha', 'add')
      );
      allow update: if isSignedIn() && (
        hasPermission('fotos', 'edit') || hasPermission('ficha', 'edit')
      );
      allow delete: if isSignedIn() && (
        hasPermission('fotos', 'delete') || hasPermission('ficha', 'delete')
      );
    }

    match /reports/{reportId} {
      allow read: if hasPermission('ficha', 'view') || hasPermission('resumen', 'view');
      allow create: if hasPermission('ficha', 'add') || hasPermission('cargar-ficha', 'add');
      allow update: if hasPermission('ficha', 'edit') || hasPermission('cargar-ficha', 'edit');
      allow delete: if hasPermission('ficha', 'delete');
    }

    match /solicitudes-capacitacion/{solicitudId} {
      allow get: if isSignedIn() && hasPermission('solicitud-capacitacion', 'view');
      allow list: if isSignedIn() && (
        hasPermission('solicitud-capacitacion', 'view') || 
        hasPermission('agenda-capacitacion', 'view') ||
        hasPermission('encuesta-satisfaccion', 'view') ||
        hasPermission('informe-divulgador', 'view') ||
        hasPermission('control-movimiento-maquinas', 'view')
      );
      allow create: if hasPermission('solicitud-capacitacion', 'add');
      allow update: if hasPermission('agenda-capacitacion', 'edit') || hasGlobalPermission('assign_staff');
      allow delete: if hasPermission('agenda-capacitacion', 'delete');
    }

    match /encuestas-satisfaccion/{encuestaId} {
      allow read: if hasPermission('encuesta-satisfaccion', 'view') || hasPermission('estadisticas-capacitacion', 'view');
      allow create: if hasPermission('encuesta-satisfaccion', 'add');
      allow update: if hasPermission('encuesta-satisfaccion', 'edit');
      allow delete: if hasPermission('encuesta-satisfaccion', 'delete');
    }

    match /informes-divulgador/{informeId} {
      allow read: if hasPermission('informe-divulgador', 'view') || hasPermission('informe-semanal-puntos-fijos', 'view');
      allow create: if hasPermission('informe-divulgador', 'add');
      allow update: if hasPermission('informe-divulgador', 'edit');
      allow delete: if hasPermission('informe-divulgador', 'delete');
    }

    match /informes-semanales-anexo-iv/{informeId} {
      allow read: if hasPermission('informe-semanal-puntos-fijos', 'view');
      allow create: if hasPermission('informe-semanal-puntos-fijos', 'add');
      allow update: if hasPermission('informe-semanal-puntos-fijos', 'edit');
      allow delete: if hasPermission('informe-semanal-puntos-fijos', 'delete');
    }

    match /movimientos-maquinas/{movimientoId} {
      allow read: if hasPermission('control-movimiento-maquinas', 'view');
      allow create: if hasPermission('control-movimiento-maquinas', 'add');
      allow update: if hasPermission('control-movimiento-maquinas', 'edit');
      allow delete: if hasPermission('control-movimiento-maquinas', 'delete');
    }

    match /padron/{padronId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** User Profiles **/
    match /users/{userId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isAdmin() || (hasPermission('users', 'view'));
        allow create: if isAdmin() || (hasPermission('users', 'add'));
        allow update: if isOwner(userId) || isAdmin() || (hasPermission('users', 'edit'));
        allow delete: if isAdmin() || (hasPermission('users', 'delete'));
    }
  }
}
