/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with user-specific data isolation.
 *
 * Data Structure:
 * - /datos/{datoId}: Public data of department and district pairs.
 * - /departamentos/{departamentoId}: Public data about departments.
 * - /departamentos/{departamentoId}/distritos/{distritoId}: Public data about districts within a department.
 * - /imagenes/{imagenId}: Publicly accessible images.
 * - /users/{userId}: Private user profile data, accessible only to the user themselves.
 * - /reports/{reportId}: Publicly accessible report data.
 *
 * Key Security Decisions:
 * - User profiles (/users/{userId}) are strictly private, accessible only to the authenticated user.
 * - Other collections (/datos, /departamentos, /imagenes, /reports) are publicly readable.
 * - Write access (create, update, delete) to all collections is open to any authenticated user.
 *   This assumes that all data is considered public and that anyone should be able to contribute.
 *   In a production environment, this would need to be restricted based on roles or ownership.
 *
 * Denormalization for Authorization:
 * - Not explicitly used in this configuration, but consider adding fields like `ownerId` to documents in `/imagenes` and `/reports` to control write access in a future iteration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read and write department and district data.
     * @path /datos/{datoId}
     * @allow (get, list): Any user can read the data.
     * @allow (create, update, delete): Any signed-in user can modify the data.
     * @deny (create, update, delete): Not signed-in user can modify the data.
     * @principle Publicly available data with open writes for signed-in users.
     */
    match /datos/{datoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Allows anyone to read and write department information.
     * @path /departamentos/{departamentoId}
     * @allow (get, list): Any user can read the data.
     * @allow (create, update, delete): Any signed-in user can modify the data.
     * @deny (create, update, delete): Not signed-in user can modify the data.
     * @principle Publicly available data with open writes for signed-in users.
     */
    match /departamentos/{departamentoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Allows anyone to read and write district information within a department.
     * @path /departamentos/{departamentoId}/distritos/{distritoId}
     * @allow (get, list): Any user can read the data.
     * @allow (create, update, delete): Any signed-in user can modify the data.
     * @deny (create, update, delete): Not signed-in user can modify the data.
     * @principle Publicly available data with open writes for signed-in users.
     */
    match /departamentos/{departamentoId}/distritos/{distritoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Allows anyone to read and write image information.
     * @path /imagenes/{imagenId}
     * @allow (get, list): Any user can read the data.
     * @allow (create, update, delete): Any signed-in user can modify the data.
     * @deny (create, update, delete): Not signed-in user can modify the data.
     * @principle Publicly available data with open writes for signed-in users.
     */
    match /imagenes/{imagenId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * @description Allows a user to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get): A user can read their own profile.
     * @allow (list): A signed-in user can list all user profiles.
     * @allow (create): A user can create their own profile if the userId matches their auth.uid.
     * @allow (update): A user can update their own profile if the userId matches their auth.uid and the document exists.
     * @allow (delete): A user can delete their own profile if the userId matches their auth.uid and the document exists.
     * @deny (get): A user cannot read other user profiles.
     * @deny (create, update, delete): A user cannot create, update, or delete other user profiles.
     * @principle Enforces user-specific data isolation for profile information while allowing listing for authenticated users.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows anyone to read and write report information.
     * @path /reports/{reportId}
     * @allow (get, list): Any user can read the data.
     * @allow (create, update, delete): Any signed-in user can modify the data.
     * @deny (create, update, delete): Not signed-in user can modify the data.
     * @principle Publicly available data with open writes for signed-in users.
     */
    match /reports/{reportId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }

  /**
   * @description Checks if the user is signed in.
   * @return {bool} True if the user is signed in, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }

  /**
   * @description Checks if the user is the owner of the document.
   * @param {string} userId The user ID to compare against the request's authentication UID.
   * @return {bool} True if the user is the owner, false otherwise.
   */
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  /**
   * @description Checks if the user is the owner of an existing document.
   * @param {string} userId The user ID to compare against the's authentication UID.
   * @return {bool} True if the user is the owner and the document exists, false otherwise.
   */
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}
