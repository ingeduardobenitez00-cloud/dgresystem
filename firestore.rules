rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // PUBLIC COLLECTIONS
    // -------------------------

    match /datos/{datoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /departamentos/{departamentoId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /distritos/{distritoId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /imagenes/{imagenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /reports/{reportId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // -------------------------
    // USERS COLLECTION (ROLE-BASED ACCESS)
    // -------------------------
    match /users/{userId} {

      // 🔹 Lectura
      allow get: if canReadUser(userId);
      allow list: if isSignedIn();

      // 🔹 Escritura
      allow create: if isOwner(userId) || isAdmin();
      allow update: if canUpdateUser(userId);
      allow delete: if isAdmin() || isExistingOwner(userId);
    }
  }

  // -------------------------
  // HELPER FUNCTIONS
  // -------------------------

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }

  // 🔹 Permitir obtener el rol del usuario actual sin bloquear la evaluación
  function userRole() {
    return exists(/databases/$(database)/documents/users/$(request.auth.uid))
      ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
      : null;
  }

  // 🔹 Roles
  function isAdmin() {
    return isSignedIn() && userRole() == 'admin';
  }

  function isEditor() {
    return isSignedIn() && userRole() == 'editor';
  }

  function isViewer() {
    return isSignedIn() && userRole() == 'visualizador';
  }

  // -------------------------
  // PERMISOS SEGÚN ROL
  // -------------------------

  // Lectura
  function canReadUser(userId) {
    // ⚠️ Importante: permitir al usuario leer su propio documento
    return isSignedIn() && (isAdmin() || isEditor() || isViewer() || isOwner(userId));
  }

  // Actualización
  function canUpdateUser(userId) {
    // Admin puede actualizar todos
    // Editor solo el suyo
    return isAdmin() || (isEditor() && isOwner(userId));
  }
}
