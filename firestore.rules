rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // 1. FUNCIONES DE AUTORIZACIÓN (JERARQUÍA)
    // ======================================================

    // Bypass por Email (Para asegurar acceso inicial y emergencias)
    function isMasterEmail() {
      return request.auth != null && 
             (
               request.auth.token.email == 'edubtz11@gmail.com' || 
               request.auth.token.email == 'eduardobritz1@gmail.com' || 
               request.auth.token.email == 'eduardobritz11@gmail.com' ||
               request.auth.token.email == 'ing.eduardobenitez00@gmail.com'
             );
    }

    // Verifica si el usuario tiene un rol específico en la colección /users
    function hasRole(roleName) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName;
    }

    // Super Administrador: Email maestro O rol 'admin' en la BD
    function isSuperAdmin() {
      return isMasterEmail() || hasRole('admin');
    }

    // Administrador: Rol 'admin' en la BD
    function isAdmin() {
      return hasRole('admin');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ======================================================
    // 2. REGLA MAESTRA (BYPASS)
    // ======================================================

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ======================================================
    // 3. REGLAS ESPECÍFICAS
    // ======================================================

    match /users/{userId} {
      // Lectura: Propia, o por parte de cualquier Admin/SuperAdmin
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSuperAdmin());
      
      // Creación y Edición: Permitido para Admins y SuperAdmins
      allow create, update: if isAdmin() || isSuperAdmin();
      
      // Eliminación: Reservado para Super Administradores
      allow delete: if isSuperAdmin();
    }

    // Colecciones Operativas
    match /solicitudes-capacitacion/{id} { allow read, write: if isSignedIn(); }
    match /informes-divulgador/{id} { allow read, write: if isSignedIn(); }
    match /informes-semanales-anexo-iv/{id} { allow read, write: if isSignedIn(); }
    match /movimientos-maquinas/{id} { allow read, write: if isSignedIn(); }
    match /divulgadores/{id} { allow read, write: if isSignedIn(); }
    match /maquinas/{id} { allow read, write: if isSignedIn(); }
    
    // Colecciones Maestras
    match /datos/{id} { 
      allow read: if true; 
      allow write: if isAdmin() || isSuperAdmin(); 
    }
    match /partidos-politicos/{id} { 
      allow read: if true; 
      allow write: if isAdmin() || isSuperAdmin(); 
    }
    
    // Encuestas y Notificaciones
    match /encuestas-satisfaccion/{id} { allow read: if isSignedIn(); allow create: if true; }
    match /notificaciones/{id} { allow read, write, create: if isSignedIn(); }
    
    // Otros módulos
    match /padron/{id} { allow read, write: if isSignedIn(); }
    match /locales-votacion/{id} { allow read, write: if isSignedIn(); }
    match /informes-semanales-registro/{id} { allow read, write: if isSignedIn(); }
    match /anexo-i/{id} { allow read, write: if isSignedIn(); }
    match /config/{id} { allow read, write: if isSignedIn(); }
    match /auditoria/{id} { allow create, read: if isSignedIn(); }
    match /presencia/{userId} { allow read, write: if isSignedIn() && request.auth.uid == userId; }
    match /archivos-semanales-registro/{id} { allow read, write: if isAdmin() || isSuperAdmin(); }
  }
}