
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * REGLAS DE SEGURIDAD CIDEE 2026 
     * Actualizadas para permitir flujo ininterrumpido de Denuncias y Movimientos.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'admin';
    }

    function isDirector() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'director';
    }

    /** Regla para Configuración Global **/
    match /config/{configId} {
      allow read: if isSignedIn() || configId == 'reporte_semanal'; 
      allow write: if isAdmin();
    }

    /** Regla para Auditoría - Permite registro de logs a todo usuario logueado **/
    match /auditoria/{logId} {
      allow read: if isAdmin() || isDirector();
      allow create: if isSignedIn();
    }

    /** Regla para Presencia **/
    match /presencia/{userId} {
      allow read: if isAdmin() || isDirector();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    /** Regla para el Padrón Electoral **/
    match /padron/{document=**} {
      allow read: if isSignedIn();
    }

    /** Regla para Personal Operativo **/
    match /divulgadores/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /** Regla para Inventario de Máquinas **/
    match /maquinas/{maquinaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Reglas Generales de Geografía **/
    match /datos/{datoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** Gestión de Usuarios **/
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'jefe');
      allow update: if (request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /** CIDEE - Colecciones Transaccionales (Alta disponibilidad operativa) **/
    
    match /anexo-i/{anexoId} {
      allow read, write: if isSignedIn();
    }

    match /solicitudes-capacitacion/{solicitudId} {
      allow get: if true; // Habilita carga de datos para ciudadanos externos (Encuesta)
      allow list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /encuestas-satisfaccion/{encuestaId} {
      allow read: if isSignedIn();
      allow create: if true; // Ciudadanos sin login pueden responder
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /informes-divulgador/{informeId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /informes-semanales-anexo-iv/{informeId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /informes-semanales-registro/{informeId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /archivos-semanales-registro/{archivoId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /movimientos-maquinas/{movimientoId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /denuncias-lacres/{denunciaId} {
      allow read, write: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /partidos-politicos/{partidoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /locales-votacion/{localId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /imagenes/{imagenId} {
      allow read, write: if isSignedIn();
    }
  }
}
