rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // BYPASS MAESTRO - ACCESO TOTAL PARA ADMINISTRADORES
    // ======================================================
    // Esta regla es la más importante. Si el correo coincide,
    // se ignora cualquier otra restricción posterior.
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == 'edubtz11@gmail.com';
    }

    // Aplicar acceso total inmediato a TODA la base de datos para Master Admins
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // ======================================================
    // REGLAS PARA OTROS USUARIOS (SE EVALÚAN SI NO ERES ADMIN)
    // ======================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isMasterAdmin() || (data != null && data.role == 'admin');
    }

    /** Gestión de Usuarios **/
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    /** CIDEE - Colecciones **/
    match /solicitudes-capacitacion/{id} {
      allow read, write: if isSignedIn();
    }
    match /informes-divulgador/{id} {
      allow read, write: if isSignedIn();
    }
    match /informes-semanales-anexo-iv/{id} {
      allow read, write: if isSignedIn();
    }
    match /movimientos-maquinas/{id} {
      allow read, write: if isSignedIn();
    }
    match /denuncias-lacres/{id} {
      allow read, write: if isSignedIn();
    }
    match /encuestas-satisfaccion/{id} {
      allow read: if isSignedIn();
      allow create: if true;
    }

    /** Configuración y Geografía **/
    match /datos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }
    match /partidos-politicos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }
    match /maquinas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    match /divulgadores/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /** Auditoría y Presencia **/
    match /auditoria/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isAdmin();
    }
    match /presencia/{userId} {
      allow read, write: if isSignedIn();
    }
    match /notificaciones/{id} {
      allow read, write: if isSignedIn();
    }

    /** Padrón (Acceso Público para lectura, escritura protegida) **/
    match /padron/{id} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin();
    }
    
    /** Registros Edilicios **/
    match /reports/{id} {
      allow read, write: if isSignedIn();
    }
    match /imagenes/{id} {
      allow read, write: if isSignedIn();
    }
    match /locales-votacion/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    match /informes-semanales-registro/{id} {
      allow read, write: if isSignedIn();
    }
    match /archivos-semanales-registro/{id} {
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}