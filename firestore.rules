/**
 * @file Firebase Security Rules for Firestore.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and allows public read access to image metadata while enforcing owner-only write access.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the user.
 * - /imagenes/{imagenId}: Stores image metadata, publicly readable but writable only by the image's owner.
 * - /datos/{datoId}: Stores department and district data, publicly readable but writable only by authenticated users.
 * - /departamentos/{departamentoId}: Stores department information, publicly readable but writable only by authenticated users.
 * - /departamentos/{departamentoId}/distritos/{distritoId}: Stores district information, publicly readable but writable only by authenticated users.
 * - /reports/{reportId}: Stores report information, publicly readable but writable only by authenticated users.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Public read access is granted to /imagenes/{imageId} and subcollections to allow for data discovery.
 * - Default security posture for ambiguous relationships is strict owner-only access.
 *
 * Denormalization for Authorization:
 * - The /imagenes/{imagenId} documents are assumed to have a field (e.g., 'authorId') that stores the user ID of the image's owner. This is essential for implementing owner-only write access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID.
     * @param {string} userId - The user ID to compare against.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of an existing document.
     * @param {string} userId - The user ID to compare against.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Stores user profile information.
     * @path /users/{userId}
     * @allow (create) User 'Hhp2XXVG1fTNC8baD1HdBIwrJLt1' can create profile at /users/Hhp2XXVG1fTNC8baD1HdBIwrJLt1.
     * @deny (create) User 'Hhp2XXVG1fTNC8baD1HdBIwrJLt1' cannot create profile at /users/differentUserId.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.email == request.auth.token.email;
      allow update: if isExistingOwner(userId) && request.resource.data.email == resource.data.email;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores image information, linked by department and district name.
     * @path /imagenes/{imagenId}
     * @allow (get) Any user can read image metadata.
     * @allow (create) User 'Hhp2XXVG1fTNC8baD1HdBIwrJLt1' can create an image with authorId: 'Hhp2XXVG1fTNC8baD1HdBIwrJLt1'.
     * @deny (update) User 'Hhp2XXVG1fTNC8baD1HdBIwrJLt1' cannot update an image they don't own.
     * @principle Enforces document ownership for writes, allows public reads.
     */
    match /imagenes/{imagenId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores imported department and district data.
     * @path /datos/{datoId}
     */
    match /datos/{datoId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores department information.
     * @path /departamentos/{departamentoId}
     */
    match /departamentos/{departamentoId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores district information for a specific department.
     * @path /departamentos/{departamentoId}/distritos/{distritoId}
     */
    match /departamentos/{departamentoId}/distritos/{distritoId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores detailed report information.
     * @path /reports/{reportId}
     */
    match /reports/{reportId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}