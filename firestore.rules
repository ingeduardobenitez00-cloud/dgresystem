rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================
    // 1. REGLA MAESTRA: BYPASS ABSOLUTO POR CORREO
    // ======================================================
    // Otorga acceso total e incondicional a los correos autorizados.
    // Esta es la primera instrucción para garantizar que el Admin nunca sea bloqueado.
    
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email.lower() == 'edubtz11@gmail.com' || 
        request.auth.token.email.lower() == 'eduardobritz1@gmail.com' || 
        request.auth.token.email.lower() == 'eduardobritz11@gmail.com' ||
        request.auth.token.email.lower() == 'ing.eduardobenitez00@gmail.com'
      );
    }

    // ======================================================
    // 2. FUNCIONES DE APOYO PARA OTROS ROLES
    // ======================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    // ======================================================
    // 3. REGLAS POR COLECCIÓN (PARA USUARIOS NO MAESTROS)
    // ======================================================

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == userId);
    }

    match /solicitudes-capacitacion/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /informes-divulgador/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /informes-semanales-anexo-iv/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /movimientos-maquinas/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /encuestas-satisfaccion/{id} {
      allow read: if isSignedIn();
      allow create: if true; 
    }

    match /datos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /partidos-politicos/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /maquinas/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /divulgadores/{id} {
      allow read, write: if isSignedIn();
    }

    match /auditoria/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
    }
    
    match /presencia/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /notificaciones/{id} {
      allow read, write: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /padron/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /reports/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /imagenes/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /locales-votacion/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /informes-semanales-registro/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /anexo-i/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /config/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /archivos-semanales-registro/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /denuncias-lacres/{id} {
      allow read, write: if isSignedIn();
    }
  }
}